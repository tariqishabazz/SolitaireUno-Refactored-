@page "/"
@using SolitaireUno

<PageTitle>Solitaire Uno</PageTitle>

<style>
    /* 1. Classic Solitaire Card Design */
    /* Classic Solitaire Card Design */
    .solitaire-card {
        width: 100px;
        height: 150px;
        background-color: white;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.0rem;
        font-weight: 800;
        text-align: center;
        box-shadow: 2px 4px 8px rgba(0,0,0,0.3);
        border: 1px solid #ddd;
        cursor: pointer;
        padding: 10px;
        user-select: none;
        transition: transform 0.2s, box-shadow 0.2s;
        border: double, 5px, green;
    }

    .solitaire-card:hover {
        transform: translateY(-10px);
        box-shadow: 4px 10px 15px rgba(0,0,0,0.4);
    }

    /* Traditional Inks */
    .card-red { color: #d62828; }   
    .card-black { color: #111111; } 
    .card-special { color: #d4af37; background-color: #333; border: 2px solid #d4af37; }

    /* 2. Classic Blue Deck Backing */
    .solitaire-deck {
        width: 100px;
        height: 150px;
        border-radius: 8px;
        border: 4px solid white;
        background: repeating-linear-gradient(
            45deg,
            #0b3954,
            #0b3954 5px,
            #082b40 5px,
            #082b40 10px
        );
        box-shadow: -1px -1px 0 #aaa, -2px -2px 0 #fff, -3px -3px 0 #aaa, -4px -4px 0 #fff, -5px -5px 0 #aaa;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: bold;
        font-size: 14px;
        transition: transform 0.1s;
    }

    .solitaire-deck:active {
        transform: translate(-3px, -3px);
    }

    /* 3. The Floating Animations */
    /* Swoops in from the Deck area down to the Hand */
    @@keyframes dealToHand {
        0% { opacity: 0; transform: translate(-100px, -200px) scale(0.6) rotate(-15deg); }
        100% { opacity: 1; transform: translate(0, 0) scale(1) rotate(0deg); }
    }

    /* Swoops up from the Hand area to the Table */
    @@keyframes playToTable {
        0% { opacity: 0; transform: translateY(150px) scale(0.8) rotate(15deg); }
        100% { opacity: 1; transform: translateY(0) scale(1) rotate(0deg); }
    }

    .animate-draw {
        animation: dealToHand 1.2s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    }

    .animate-play {
        animation: playToTable 1.2s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    }
</style>

<div class="text-center">
    <h1 class="mt-3" style="font-family: serif;">Solitaire Uno</h1>
    <hr />

@if (!gameStarted)
    {
        <div class="card p-4 mx-auto shadow-sm mt-4" style="max-width: 350px; background-color: #f8f9fa;">
            <h4 class="mb-3 text-dark">Game Setup</h4>

            <label class="form-label fw-bold text-dark text-start">Game Mode</label>
            <select class="form-select mb-3" @bind="selectedMode">
                <option value="@GameMode.Ascending">Ascending</option>
                <option value="@GameMode.Descending">Descending</option>
            </select>

            <label class="form-label fw-bold text-dark text-start">Difficulty</label>
            <select class="form-select mb-4" @bind="selectedDifficulty">
                <option value="@GameDifficulty.Easy">Easy</option>
                <option value="@GameDifficulty.Medium">Medium</option>
                <option value="@GameDifficulty.Hard">Hard</option>
            </select>

            
            <label class="form-label fw-bold text-dark text-start">Card Backing Color</label>
            <select class="form-select mb-4" @bind="selectedCardColor" >
                <option value="yellow">Yellow</option>
                <option value="red">Red</option>
                <option value="blue">Blue</option>
                <option value="green">Green</option>
            </select>
            

            <div class="form-check mb-4 text-start">
                <input class="form-check-input" type="checkbox" id="suitEnforcement" @bind="suitEnforcement" />
                <label class="form-check-label fw-bold text-dark" for="suitEnforcement">
                    Enable Suit Enforcement
                </label>
            </div>

            <button class="btn btn-lg btn-success w-100 fw-bold" @onclick="StartNewGame">Start Game</button>
        </div>
    }
    else
    {
        <div class="game-board mt-4">

            <div class="p-5 my-4 d-flex flex-column align-items-center" style="background-color: #35654d; border-radius: 12px; box-shadow: inset 0 0 30px rgba(0,0,0,0.6);">
				<h5 class="text-danger mb-3">Opponent Cards: @MainGame.computer.Hand.Count</h5>

				<div class="alert alert-light border shadow-sm" role="alert" style="font-size: 1.1rem;">
					@actionLog
				</div>
                
                <div class="d-flex justify-content-center align-items-center gap-5 my-2">
                    <div class="text-center">
                        <div class="solitaire-deck" @onclick='() => PlayTurn("p.u")' style="padding: 0; border: none; background: transparent; box-shadow: none;">
                            <img src=@($"images/cards/{selectedCardColor}_backing.png") alt="Deck" style="width: 100%; height: 100%; object-fit: cover; border-radius: 8px; image-rendering: pixelated;" />
                        </div>
                    </div>

                    <div class="text-center" @key="MainGame.VisualCard">
                        <div class="solitaire-card animate-play" style="padding: 0; overflow: hidden; border: none; background: transparent; box-shadow: none;">
                            <img src="@GetCardImagePath(MainGame.VisualCard)" alt="@MainGame.VisualCard?.ToString()" style="width: 100%; height: 100%; object-fit: cover; border-radius: 8px; image-rendering: pixelated;" />
                        </div>
                    </div>

                    @if (MainGame.VisualCard is SpecialCard)
                    {
                        <div class="text-center ms-4" style="opacity: 0.7; transform: scale(0.85);">
                            <div class="solitaire-card" style="padding: 0; overflow: hidden; border: none; background: transparent; box-shadow: none;">
                                <img src="@GetCardImagePath(MainGame.LogicCard)" alt="@MainGame.LogicCard?.ToString()" style="width: 100%; height: 100%; object-fit: cover; border-radius: 8px; image-rendering: pixelated;" />
                            </div>
                            <span class="text-white mt-2 d-block fw-bold">Underneath</span>
                        </div>
                    }

                </div>

                <div class="text-white mt-4 opacity-75">
                    Order: @MainGame.GameModeChoice | Deck has @MainGame.GameDeck?.Length() cards left!
                </div>
                <button class="btn btn-outline-light mt-3 px-4" @onclick='() => PlayTurn("pass")'>Pass Turn</button>
            </div>

            <h4 class="mt-4" style="color: #444;">Your Hand (@MainGame.player.Hand.Count cards) </h4>
            <div class="d-flex flex-wrap justify-content-center gap-2 mt-3 p-2">
                @for (int i = 0; i < MainGame.player.Hand.Count; i++)
                {
                    var card = MainGame.player.Hand[i];
                    int buttonIndex = i + 1;

                    <div @key="card" class="solitaire-card animate-draw" @onclick='() => PlayTurn(buttonIndex.ToString())' style="padding: 0; overflow: hidden; border: none; background: transparent; box-shadow: none;">
                        <img src="@GetCardImagePath(card)" alt="@card.ToString()" style="width: 100%; height: 100%; object-fit: cover; border-radius: 8px; image-rendering: pixelated;" />
                    </div>
                }
            </div>

            @if (gameOverMessage != "")
            {
                <h2 class="text-success mt-4">@gameOverMessage</h2>
                <br />
            }
        </div>
    }
</div>

@code 
{
    private MainGame? gameEngine;

    private bool gameStarted = false;
    private bool isComputerThinking = false;
    private bool suitEnforcement = false;

    private string gameOverMessage = "";
    private string actionLog = "Welcome to Solitaire Uno!";

    private GameMode selectedMode = GameMode.Ascending;
    private GameDifficulty selectedDifficulty = GameDifficulty.Easy;
    private string selectedCardColor = "yellow";

    private void StartNewGame()
    {
        Deck freshDeck = new Deck();
        gameEngine = new MainGame(freshDeck, selectedMode, suitEnforcement, selectedDifficulty);

        gameEngine.StartGame();
        gameStarted = true;
        actionLog = "Cards dealt. It is your turn.";
    }

    private async Task PlayTurn(string decision)
    {
        if (isComputerThinking || gameOverMessage != "")
            return;

        // -------------------------- PLAYER'S TURN ---------------------------------

        string turnResult = gameEngine?.AdvanceTurn(decision) ?? "";
        if(!string.IsNullOrEmpty(turnResult))
        {
            actionLog = turnResult;
        }

        if (MainGame.player.Hand.Count == 0)
        {
            gameOverMessage = "You Win! 🎉";
            return;
        }

        // -------------------------- COMPUTER'S TURN ---------------------------------

        while (!MainGame.IsPlayerTurn && MainGame.computer.Hand.Count > 0)
        {
            isComputerThinking = true;
            actionLog = "Opponent is thinking...";
            StateHasChanged();

            Random random = new Random();
            int randomWaitingPeriod = random.Next(5) + 1;

            switch (randomWaitingPeriod)
            {
                case 1:
                    await Task.Delay(2000);
                    break;

                case 2:
                    await Task.Delay(2500);
                    break;

                case 3:
                    await Task.Delay(3000);
                    break;

                default:
                    await Task.Delay(3500);
                    break;
            }

            turnResult = gameEngine?.AdvanceTurn("") ?? "";
            
            if(!string.IsNullOrEmpty(turnResult))
                actionLog = turnResult;


            if (MainGame.computer.Hand.Count == 0)
            {
                gameOverMessage = "Opponent Wins!";
                isComputerThinking = false;
                return;
            }
        }

        isComputerThinking = false;
        
        if (MainGame.IsPlayerTurn)
            actionLog += "\nYour turn.";
    }

    /// <summary>
    /// Colors the card depending on the card's suit.
    /// </summary>
    /// <param name="card"></param>
    /// <returns>For Hearts/Diamonds, returns a red card. 
    ///     For other suits, returns a black card. 
    ///     For non-suited cards, returns special card coloring</returns>
    private string GetCardColor(Card? card)
    {
        if (card is RegularCard regCard)
        {
            if (regCard.Suit == Suits.Hearts || regCard.Suit == Suits.Diamonds)
                return "card-red";
            else
                return "card-black";
        }
        return "card-special";
    }

    private string GetCardImagePath(Card? card)
    {
        if (card is null)
            return "";

        if (card is RegularCard regularCard)
            return $"images/cards/{regularCard.Value.ToString().ToLower()}_of_{regularCard.Suit.ToString().ToLower()}.png";

        // re-edit once user can choose preferred card color
        else if (card is SpecialCard specialCard)
        {
            switch (specialCard.CardType)
            {
                case SpecialCardType.DrawFour:
                    return $"images/cards/drawfour.png";

                case SpecialCardType.DrawTwo:
                    return $"images/cards/{selectedCardColor}_draw_two.png";

                case SpecialCardType.Skip:
                    return $"images/cards/{selectedCardColor}_skip.png";
            }
        }
        return $"images/cards/{selectedCardColor}_backing.png";
    } 
}